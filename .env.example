# Copy to .env / .env.local and fill in. Next.js and Prisma load `.env` then `.env.local` (override).
# `npx prisma migrate deploy` uses the same order via prisma.config.ts — migrate the DB that matches your active DATABASE_URL.

# Required for app + Prisma
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── WorkOS AuthKit (SSO) ─────────────────────────────────────────────────────
# From WorkOS dashboard → API Keys
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# Callback URL registered in WorkOS dashboard → Redirects
# Local: http://localhost:3000/callback  |  Prod: https://nexus-ai-yv.vercel.app/callback
# BOTH vars required: WORKOS_REDIRECT_URI (server) + NEXT_PUBLIC_ (Edge/middleware)
WORKOS_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
# Required for session encryption
WORKOS_COOKIE_PASSWORD=

# Hightouch → /api/ingest/* and /api/decide
HIGHTOUCH_API_KEY=

# Vercel Cron → /api/cron/select-and-send
CRON_SECRET=

# Braze REST (cron + settings UI)
BRAZE_API_KEY=
BRAZE_REST_URL=https://rest.iad-01.braze.com
# Optional — platform app identifiers when building payloads
# BRAZE_ANDROID_APP_ID=
# BRAZE_IOS_APP_ID=
# BRAZE_WEB_APP_ID=
