# Copy to .env / .env.local and fill in. Next.js and Prisma load `.env` then `.env.local` (override).
# `npx prisma migrate deploy` uses the same order via prisma.config.ts — migrate the DB that matches your active DATABASE_URL.

# Required for app + Prisma
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── Better Auth + Google SSO ─────────────────────────────────────────────────
# Random secret for signing/encrypting sessions — generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL of this app (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000
# Public base URL — used by the client-side auth helper
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Google OAuth — from console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI must include: <APP_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Hightouch → /api/ingest/* and /api/decide
HIGHTOUCH_API_KEY=

# Vercel Cron → /api/cron/select-and-send
CRON_SECRET=

# Braze REST (cron + settings UI)
BRAZE_API_KEY=
BRAZE_REST_URL=https://rest.iad-01.braze.com
# Optional — platform app identifiers when building payloads
# BRAZE_ANDROID_APP_ID=
# BRAZE_IOS_APP_ID=
# BRAZE_WEB_APP_ID=
