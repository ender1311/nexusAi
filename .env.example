# Database
DATABASE_URL="file:./dev.db"

# Ingest API - shared secret for Hightouch → this app authentication
# Set this in your Hightouch HTTP destination as: Authorization: Bearer <value>
INGEST_API_KEY=

# Braze Configuration
BRAZE_API_KEY=
BRAZE_REST_URL=rest.iad-01.braze.com
BRAZE_ANDROID_APP_ID=
BRAZE_IOS_APP_ID=
BRAZE_WEB_APP_ID=
BRAZE_APP_GROUP_ID=

# BigQuery Configuration
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET=
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
