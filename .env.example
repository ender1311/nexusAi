# Copy to .env / .env.local and fill in. Next.js and Prisma load `.env` then `.env.local` (override).
# `npx prisma migrate deploy` uses the same order via prisma.config.ts — migrate the DB that matches your active DATABASE_URL.

# Required for app + Prisma
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── WorkOS AuthKit (SSO) ─────────────────────────────────────────────────────
# From WorkOS dashboard → API Keys
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# Callback URL registered in WorkOS dashboard → Redirects
# Local: http://localhost:3000/callback  |  Prod: https://nexus.youversion.com/callback
# BOTH vars required: WORKOS_REDIRECT_URI (server) + NEXT_PUBLIC_ (Edge/middleware)
WORKOS_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
# Required for session encryption
WORKOS_COOKIE_PASSWORD=

# Hightouch → /api/ingest/* and /api/decide
HIGHTOUCH_API_KEY=

# YouVersion Guided Prayer API (prayer.youversionapi.com/4.0) — Bearer token
# Required for {{gp_reference}} / {{gp_text}} liquid tags in Guided Prayer push variants.
# Obtain a fresh token from the YouVersion API team (YV_API_KEY / yv_api_key in alfred config).
GUIDED_PRAYER_API_KEY=

# Vercel Cron → /api/cron/select-and-send
CRON_SECRET=

# Test DB safety flag — set only in .env.test (never .env.local)
# truncateAll() in tests/helpers/db.ts requires this to prevent accidental production wipes
# TEST_DB=true

# Braze REST (cron + settings UI)
BRAZE_API_KEY=
BRAZE_REST_ENDPOINT=https://rest.iad-01.braze.com
# Nexus campaign — all sends are attributed to this campaign in Braze analytics.
# Must match the API identifier shown in Braze → Campaigns → <Nexus campaign> → Settings.
# Without this, sends go through /messages/send with no campaign_id and are invisible to analytics.
BRAZE_NEXUS_CAMPAIGN_ID=
# Message variation IDs within the Nexus campaign (used for per-channel analytics attribution).
# Found in Braze → Campaigns → <Nexus campaign> → each variant's settings.
BRAZE_NEXUS_IOS_VARIANT_ID=
BRAZE_NEXUS_ANDROID_VARIANT_ID=
BRAZE_NEXUS_EMAIL_VARIANT_ID=
BRAZE_NEXUS_CONTENTCARD_VARIANT_ID=
# Optional — platform app identifiers when building payloads
# BRAZE_ANDROID_APP_ID=
# BRAZE_IOS_APP_ID=
# BRAZE_WEB_APP_ID=

# ── API Service (separate Bun/Hono server) ─────────────────────────────────────
# Shared secret for Next.js → API service calls (bearer token)
INTERNAL_API_SECRET=
# Shared secret for API service → Next.js cache revalidation webhook
REVALIDATE_SECRET=
# Base URL of the API service (local: http://localhost:3001, prod: https://nexus-api.fly.dev)
API_SERVICE_URL=
# Base URL of the Next.js app (used by API service to call revalidate webhook)
# Only needed in the API service environment
NEXT_APP_URL=
