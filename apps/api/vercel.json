{
  "framework": null,
  "installCommand": "npm install --ignore-scripts",
  "buildCommand": "npx prisma generate --config prisma.config.ts",
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs22.x"
    }
  },
  "build": {
    "env": {
      "HUSKY": "0"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }]
}
