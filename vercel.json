{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "bun run build",
  "functions": {
    "src/app/page.tsx": {
      "memory": 1024,
      "maxDuration": 30
    },
    "src/app/agents/page.tsx": {
      "memory": 512,
      "maxDuration": 20
    }
  },
  "crons": [
    {
      "path": "/api/cron/select-and-send",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/discover-personas",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/sync-template-variants",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/ingest-braze-analytics",
      "schedule": "0 */6 * * *"
    }
  ]
}
