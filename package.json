{
  "name": "nexus",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/api"],
  "scripts": {
    "dev": "next dev",
    "dev:api": "bun --cwd apps/api run dev",
    "dev:all": "bun run dev & bun run dev:api",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "bun test --bail=1 tests/unit & bun test --bail=1 tests/contracts & wait && bun test --max-concurrency=1 --timeout 30000 --bail=1 tests/integration && bun test --max-concurrency=1 --timeout 30000 --bail=1 tests/regression",
    "test:quick": "bun test --bail=1 tests/unit tests/contracts",
    "test:int": "bun test --max-concurrency=1 --timeout 30000 --bail=1",
    "test:watch": "bun test --watch tests/unit",
    "check": "bun run typecheck && bun run lint && bun run test",
    "check:quick": "bun run typecheck && bun run lint && bun run test:quick",
    "prepare": "[ -f node_modules/.bin/husky ] && husky || true"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@notionhq/client": "^5.21.0",
    "@prisma/adapter-neon": "7.8.0",
    "@prisma/client": "7.8.0",
    "@workos-inc/authkit-nextjs": "^4.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "prisma": "7.8.0",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bun": "^1.3.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
