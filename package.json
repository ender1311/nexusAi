{
  "name": "nexus",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/api"],
  "scripts": {
    "dev": "next dev",
    "dev:api": "bun --cwd apps/api run dev",
    "dev:all": "bun run dev & bun run dev:api",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "bun test --bail=1 tests/unit & u=$!; bun test --bail=1 tests/contracts & c=$!; wait $u; ur=$?; wait $c; cr=$?; [ $ur -eq 0 ] && [ $cr -eq 0 ] && bun scripts/run-int-reg.ts",
    "test:quick": "bun test --bail=1 tests/unit tests/contracts",
    "test:int": "for f in tests/integration/*.test.ts; do bun test --timeout 30000 --bail=1 \"$f\" || exit 1; done",
    "test:int-reg": "bun scripts/run-int-reg.ts",
    "test:watch": "bun test --watch tests/unit",
    "check": "bun scripts/check.ts",
    "check:quick": "bun run typecheck && bun run lint && bun run test:quick",
    "prepare": "[ -f node_modules/.bin/husky ] && husky || true"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "7.8.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@workos-inc/authkit-nextjs": "^4.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "pg": "^8.21.0",
    "prisma": "7.8.0",
    "react": "19.2.6",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.6",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.9.0",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@types/bun": "1.3.14",
    "@types/js-yaml": "4.0.9",
    "@types/node": "20.19.37",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.6",
    "husky": "9.1.7",
    "js-yaml": "4.1.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  }
}
