generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum FunnelStage {
  new
  lapsed
  connected
  activated
  engaged
  inspired
}

model Agent {
  id          String      @id @default(cuid())
  name        String
  description String?
  status      String      @default("draft")
  algorithm   String      @default("thompson")
  epsilon     Float       @default(0.1)
  funnelStage FunnelStage @default(connected)
  targetFilter Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  goals          Goal[]
  messages       Message[]
  schedulingRule SchedulingRule?
  decisions      UserDecision[]
  metrics        ModelMetric[]
  personaTargets AgentPersonaTarget[]
}

model Goal {
  id             String  @id @default(cuid())
  agentId        String
  eventName      String
  tier           String
  valueWeight    Float   @default(1.0)
  weightMode     String  @default("fixed")   // "fixed" | "property"
  weightProperty String?
  weightDefault  Float   @default(1.0)
  description    String?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Message {
  id              String   @id @default(cuid())
  agentId         String
  name            String
  channel         String
  brazeCampaignId String?
  testedVariables Json     @default("[]")
  createdAt       DateTime @default(now())

  agent    Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  variants MessageVariant[]
}

model MessageVariant {
  id                   String    @id @default(cuid())
  messageId            String
  name                 String
  subject              String?
  body                 String
  cta                  String?
  status               String    @default("active")
  brazeVariantId       String?
  title                String?
  iconImageUrl         String?
  deeplink             String?
  preferredHour        Int?
  preferredDayOfWeek   Int?
  frequencyCapOverride Json?
  warmupUntil          DateTime?
  category             String?
  sourceTemplateId     String?
  // Semantic descriptor of the message — enables oracle generalization across variants
  // { tone: "empathy"|"urgency"|"question"|"milestone", hasPersonalization: bool,
  //   ctaType: "button"|"link"|"deeplink", messageLengthBucket: "short"|"medium"|"long" }
  actionFeatures       Json?
  createdAt            DateTime  @default(now())

  message   Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  decisions UserDecision[]
}

model UserDecision {
  id               String    @id @default(cuid())
  agentId          String
  userId           String
  messageVariantId String?
  channel          String
  sentAt           DateTime  @default(now())
  brazeSendId      String?
  conversionEvent  String?
  conversionAt     DateTime?
  reward           Float?
  // Context snapshot at decide-time — used for offline analysis and oracle training
  // { giver_tier?, streak_status?, streak_days?, recency_days?, trigger_event? }
  decisionContext  Json?

  agent   Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  variant MessageVariant? @relation(fields: [messageVariantId], references: [id])

  @@index([agentId, userId, sentAt])
}

// YouVersion app user — ingested from Hightouch/Braze, used by bandit engine
model TrackedUser {
  id                String    @id @default(cuid())
  externalId        String    @unique
  attributes        Json      @default("{}")     // JSON from Hightouch

  // Accumulated behavioral stats
  totalDecisions    Int       @default(0)
  totalConversions  Int       @default(0)
  totalReward       Float     @default(0.0)
  channelStats      Json      @default("{}")     // {"push":{sent:N,converted:N},...}
  hourlyStats       Json      @default("[]")     // 24-element array [N, N, ...]
  dailyStats        Json      @default("[]")     // 7-element array [N, N, ...]

  // Feature vector (computed periodically from stats)
  featureVector     Json?
  featureVectorAt   DateTime?

  // Persona assignment
  personaId         String?
  personaConfidence Float?
  personaAssignedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  persona Persona? @relation(fields: [personaId], references: [id])

  @@index([personaId])
  @@map("User")  // keeps the existing DB table — no migration needed for this rename
}

model Persona {
  id              String    @id @default(cuid())
  name            String
  description     String?
  icon            String    @default("Users2")
  color           String    @default("blue")
  source          String    @default("manual")  // "manual" | "discovered"
  centroid        Json?                          // JSON feature vector
  clusterSize     Int       @default(0)
  silhouetteScore Float?
  traits          Json      @default("{}")       // JSON: discovered/extra fields
  label           String?
  tags            Json      @default("[]")
  isActive        Boolean   @default(true)
  discoveredAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  trackedUsers TrackedUser[]
  agentTargets AgentPersonaTarget[]
}

model AgentPersonaTarget {
  id        String @id @default(cuid())
  agentId   String
  personaId String

  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  persona Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@unique([agentId, personaId])
}

model PersonaArmStats {
  id        String @id @default(cuid())
  personaId String
  agentId   String
  variantId String
  alpha     Float  @default(1.0)
  beta      Float  @default(1.0)
  tries     Int    @default(0)
  wins      Int    @default(0)

  @@unique([personaId, agentId, variantId])
  @@index([agentId, personaId])
}

model LinUCBArm {
  id        String @id @default(cuid())
  personaId String
  agentId   String
  variantId String
  // A_inv: flattened FEATURE_DIM×FEATURE_DIM matrix (row-major), maintained via Sherman-Morrison
  aInv      Json
  // b vector: FEATURE_DIM floats (sum of reward * feature_vector across observations)
  b         Json
  tries     Int    @default(0)

  @@unique([personaId, agentId, variantId])
  @@index([agentId, personaId])
}

model SchedulingRule {
  id             String  @id @default(cuid())
  agentId        String  @unique
  frequencyCap   Json    @default("{\"maxSends\":3,\"period\":\"week\"}")
  quietHours     Json    @default("{\"start\":\"22:00\",\"end\":\"08:00\",\"timezone\":\"America/New_York\"}")
  blackoutDates  Json    @default("[]")
  smartSuppress  Boolean @default(false)
  suppressThresh Float   @default(0.5)

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model ModelMetric {
  id        String   @id @default(cuid())
  agentId   String
  timestamp DateTime @default(now())
  metrics   Json

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

// ── Plan set classification ──────────────────────────────────────────────────

model PlanSet {
  id           String    @id @default(cuid())
  setId        String    @unique          // YouVersion Cassi set_id (e.g. "10")
  collectionId String?                    // YV API collection_id resolved from set_id
  name         String                     // e.g. "New to Faith"
  slug         String?
  personaTag   String                     // maps to Persona.label (e.g. "searching", "anxious")
  syncedAt     DateTime?                  // when plan memberships were last fetched
  createdAt    DateTime  @default(now())

  members PlanSetMember[]
}

model PlanSetMember {
  planId String   // YouVersion plan_id (matches plan_day_last_plan_id Braze attribute)
  setId  String   // PlanSet.setId

  planSet PlanSet @relation(fields: [setId], references: [setId], onDelete: Cascade)

  @@id([planId, setId])
  @@index([planId])
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
