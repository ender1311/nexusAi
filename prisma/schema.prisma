generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator apiClient {
  provider = "prisma-client"
  output   = "../apps/api/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Agent {
  id          String      @id @default(cuid())
  name        String
  description String?
  status      String      @default("draft")
  algorithm   String      @default("thompson")
  epsilon     Float       @default(0.1)
  funnelStage      String      @default("wau")
  targetFilter     Json?
  fallbackSendHour Int?        // 0-23 UTC-naive hour; Braze delivers at this hour in user's local timezone via in_local_time
  audienceCap      Int?        // max users reached per cron run; null = unlimited
  languageFilter   String      @default("all") // "all" | "en" | ISO language prefix; filters by User.attributes.language_tag
  // How many days after a user falls out of the Hightouch audience we keep targeting them.
  // null = no staleness gate (backward compat). Lapsed agents typically use 14; others use 2.
  staleFunnelStageDays Int?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  goals          Goal[]
  messages       Message[]
  schedulingRule SchedulingRule?
  decisions      UserDecision[]
  metrics        ModelMetric[]
  personaTargets AgentPersonaTarget[]

  @@index([updatedAt])
  @@index([status])
}

model Goal {
  id             String  @id @default(cuid())
  agentId        String
  eventName      String
  tier           String
  valueWeight    Float   @default(1.0)
  weightMode     String  @default("fixed")   // "fixed" | "property"
  weightProperty String?
  weightDefault  Float   @default(1.0)
  description    String?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

model Message {
  id              String   @id @default(cuid())
  agentId         String
  name            String
  channel         String
  brazeCampaignId String?
  brazeCanvasId   String?  // Braze canvas UUID — set by sync-braze-canvas-ids script
  testedVariables Json     @default("[]")
  createdAt       DateTime @default(now())

  agent    Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  variants MessageVariant[]

  @@index([agentId])
}

model MessageVariant {
  id                   String    @id @default(cuid())
  messageId            String
  name                 String
  subject              String?
  body                 String
  cta                  String?
  status               String    @default("active")
  brazeVariantId       String?
  brazeCanvasStepId    String?  // Braze canvas step UUID — set by sync-braze-canvas-ids script
  title                String?
  iconImageUrl         String?
  deeplink             String?
  preferredHour        Int?
  preferredDayOfWeek   Int?
  frequencyCapOverride Json?
  warmupUntil          DateTime?
  category             String?
  subcategory          String?   // sub-goal within the category
  sourceTemplateId     String?
  // Semantic descriptor of the message — enables oracle generalization across variants
  // { tone: "empathy"|"urgency"|"question"|"milestone", hasPersonalization: bool,
  //   ctaType: "button"|"link"|"deeplink", messageLengthBucket: "short"|"medium"|"long" }
  actionFeatures       Json?
  createdAt            DateTime  @default(now())

  message       Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  sourceTemplate MessageVariant? @relation("TemplateClones", fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  clones         MessageVariant[] @relation("TemplateClones")
  decisions      UserDecision[]

  @@index([status, category, subcategory]) // variant picker API (WHERE status='active' AND category=X AND subcategory=Y)
  @@index([brazeCanvasStepId])             // canvas attribution: canvas_step_id → variant lookup
}

model Deeplink {
  id          String  @id @default(cuid())
  wayfinderId String  @unique
  category    String  // reader | plans | votd | guided-scripture | guided-prayer
  subcategory String  // open-bible | find-plans | my-plans | votd-page | todays-story | prayer-list | guided-prayer | etc.
  label       String
  description String?
  urlTemplate String
  example     String?
  sortOrder   Int     @default(0)
}

model UserDecision {
  id               String    @id @default(cuid())
  agentId          String
  userId           String
  messageVariantId String?
  channel          String
  sentAt           DateTime  @default(now())
  brazeSendId             String?
  brazeScheduleId         String?   // schedule_id returned by /messages/schedule/create
  scheduledFor            DateTime? // when Braze is scheduled to deliver this message (null = immediate)
  conversionEvent         String?
  conversionAt            DateTime?
  pushOpenAt              DateTime?  // when user opened the push — set without consuming conversionAt slot
  reward                  Float?
  brazeAnalyticsFetchedAt DateTime? // when /sends/data_series was last polled (used for daily 900-sendId cap)
  // Context snapshot at decide-time — used for offline analysis and oracle training
  // { giver_tier?, streak_status?, streak_days?, recency_days?, trigger_event? }
  decisionContext  Json?

  agent   Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  variant MessageVariant? @relation(fields: [messageVariantId], references: [id])

  @@index([agentId, userId, sentAt])
  @@index([sentAt])                   // fleet-wide 30d/24h window queries (perf page, dashboard)
  @@index([userId, sentAt])           // global daily cap + event attribution (userId + window)
  @@index([agentId, sentAt])          // per-agent performance page (agentId + 30d window)
  @@index([sentAt, brazeSendId])      // cron budget count (sentAt >= today AND brazeSendId NOT NULL)
}

// YouVersion app user — ingested from Hightouch/Braze, used by bandit engine
model TrackedUser {
  id                String    @id @default(cuid())
  externalId        String    @unique
  attributes        Json      @default("{}")     // JSON from Hightouch

  // Accumulated behavioral stats
  totalDecisions    Int       @default(0)
  totalConversions  Int       @default(0)
  totalReward       Float     @default(0.0)
  channelStats      Json      @default("{}")     // {"push":{sent:N,converted:N},...}
  hourlyStats       Json      @default("[]")     // 24-element array [N, N, ...]
  dailyStats        Json      @default("[]")     // 7-element array [N, N, ...]

  // Preferred send time (derived from last_seen_at UTC hour/minute during ingest)
  preferredSendHour   Int?   // 0-23 UTC — derived from last_seen_at hour
  preferredSendMinute Int?   // 0-59 UTC — derived from last_seen_at minute
  timezone            String? // IANA timezone string synced from Braze via Hightouch (e.g. "America/New_York")

  // Feature vector (computed periodically from stats)
  featureVector     Json?
  featureVectorAt   DateTime?

  // Braze internal user ID — populated for unverified users who have no external_user_id in Braze
  // For verified users: stored alongside their external_user_id for reference.
  // For unverified users: externalId is set to brazeId so they can be stored and targeted.
  brazeId           String?   @unique

  // Funnel stage — synced from Hightouch audience membership (optional)
  funnelStage          String?    // "lapsed" | "connected" | "new_user" | etc; null = unknown
  funnelStageUpdatedAt DateTime?  // set on every ingest when funnelStage is present; used for staleness gate in cron

  // Persona assignment
  personaId         String?
  personaConfidence Float?
  personaAssignedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  persona Persona? @relation(fields: [personaId], references: [id])

  @@index([personaId])
  @@index([funnelStage])              // cron stage filter (WHERE funnelStage = 'wau')
  @@index([personaId, funnelStage])   // cron eligibility when filtering by both persona + stage
  @@map("User")  // keeps the existing DB table — no migration needed for this rename
}

model Persona {
  id              String    @id @default(cuid())
  name            String
  description     String?
  icon            String    @default("Users2")
  color           String    @default("blue")
  source          String    @default("manual")  // "manual" | "discovered"
  centroid        Json?                          // JSON feature vector
  clusterSize     Int       @default(0)
  silhouetteScore Float?
  traits          Json      @default("{}")       // JSON: discovered/extra fields
  label           String?
  tags            Json      @default("[]")
  isActive        Boolean   @default(true)
  discoveredAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  trackedUsers TrackedUser[]
  agentTargets AgentPersonaTarget[]
}

model AgentPersonaTarget {
  id        String @id @default(cuid())
  agentId   String
  personaId String

  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  persona Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@unique([agentId, personaId])
}

model PersonaArmStats {
  id        String @id @default(cuid())
  personaId String
  agentId   String
  variantId String
  alpha     Float  @default(1.0)
  beta      Float  @default(1.0)
  tries     Int    @default(0)
  wins      Int    @default(0)

  @@unique([personaId, agentId, variantId])
  @@index([agentId, personaId])
}

model UserArmStats {
  id        String @id @default(cuid())
  userId    String  // TrackedUser.externalId (no FK — same pattern as UserDecision.userId)
  agentId   String
  variantId String
  alpha     Float  @default(1.0)
  beta      Float  @default(30.0)  // pessimistic prior matching ThompsonSampling.initialStats()
  tries     Int    @default(0)
  wins      Int    @default(0)

  @@unique([userId, agentId, variantId])
  @@index([userId, agentId])   // load all arms for a user × agent in one query
}

model LinUCBArm {
  id        String @id @default(cuid())
  agentId   String
  variantId String
  // A_inv: flattened FEATURE_DIM×FEATURE_DIM matrix (row-major), maintained via Sherman-Morrison
  aInv      Json
  // b vector: FEATURE_DIM floats (sum of reward * feature_vector across observations)
  b         Json
  tries     Int    @default(0)

  @@unique([agentId, variantId])
  @@index([agentId])
}

model SchedulingRule {
  id             String  @id @default(cuid())
  agentId        String  @unique
  frequencyCap   Json    @default("{\"maxSends\":3,\"period\":\"week\"}")
  quietHours     Json    @default("{\"start\":\"22:00\",\"end\":\"08:00\",\"timezone\":\"America/New_York\"}")
  blackoutDates  Json    @default("[]")
  smartSuppress  Boolean @default(false)
  suppressThresh Float   @default(0.5)

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model ModelMetric {
  id        String   @id @default(cuid())
  agentId   String
  timestamp DateTime @default(now())
  metrics   Json

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, timestamp])       // metrics history queries per agent
}

// ── Plan set classification ──────────────────────────────────────────────────

model PlanSet {
  id           String    @id @default(cuid())
  setId        String    @unique          // YouVersion Cassi set_id (e.g. "10")
  collectionId String?                    // YV API collection_id resolved from set_id
  name         String                     // e.g. "New to Faith"
  slug         String?
  personaTag   String                     // maps to Persona.label (e.g. "searching", "anxious")
  syncedAt     DateTime?                  // when plan memberships were last fetched
  createdAt    DateTime  @default(now())

  members PlanSetMember[]
}

model PlanSetMember {
  planId String   // YouVersion plan_id (matches plan_day_last_plan_id Braze attribute)
  setId  String   // PlanSet.setId

  planSet PlanSet @relation(fields: [setId], references: [setId], onDelete: Cascade)

  @@id([planId, setId])
  @@index([planId])
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model UserAgentAssignment {
  id                String    @id @default(cuid())
  externalUserId    String    @unique   // TrackedUser.externalId (no FK — matches UserDecision pattern)
  agentId           String              // Agent.id (no FK — assignment survives agent soft-delete)
  startedAt         DateTime  @default(now())
  sendCount         Int       @default(0)
  windowCompletedAt DateTime?           // null = in exploration; non-null = window done

  @@index([agentId])
  @@index([windowCompletedAt])
}

model CronRun {
  id         String    @id @default(cuid())
  cronName   String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  status     String    @default("running")  // "running" | "completed" | "failed"
  sent       Int       @default(0)
  suppressed Int       @default(0)
  errors     Int       @default(0)
  agentCount Int       @default(0)
  errorMsg   String?

  @@index([cronName, startedAt])
}

model FailedBrazeSend {
  id          String   @id @default(cuid())
  agentId     String
  variantId   String
  channel     String
  userIds     Json     @default("[]")
  decisionIds Json     @default("[]")
  reason      String?
  failedAt    DateTime @default(now())
  retryCount  Int      @default(0)

  @@index([agentId, failedAt])
}

// Idempotency table for event attribution — prevents double-processing when Hightouch retries a sync.
// TTL: rows older than 30 days can be pruned (no query needs older records).
model ProcessedEventId {
  eventId   String   @id             // Hightouch event_id (e.g. "braze_user_id:timestamp")
  createdAt DateTime @default(now())

  @@index([createdAt])               // used for TTL pruning
}

// System-level ingest run log — tracks received/matched/unmatched counts per sync.
model IngestSyncLog {
  id        String   @id @default(cuid())
  syncKind  String                   // "user_sync" | "push_open_events" | "conversion_events" | "braze_events"
  createdAt DateTime @default(now())
  received  Int
  upserted  Int?                     // user_sync only
  matched   Int?                     // event attribution only
  unmatched Int?                     // event attribution only
  details   Json?                    // extra metadata (deduped count, skipped_anonymous, etc.)

  @@index([syncKind, createdAt])
}

model CampaignContent {
  id            String   @id @default(cuid())
  campaign      String
  contentType   String
  language      String
  usfmReference String
  usfmHuman     String?
  title         String?
  body          String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([campaign, contentType, language, usfmReference])
  @@index([campaign, language, contentType])
  @@index([campaign, status])
}
